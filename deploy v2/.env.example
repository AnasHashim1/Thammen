# Thammen Environment Variables (Sprint 1)
#
# Copy this file to .env for local development (don't commit .env to git).
# For Heroku: heroku config:set KEY=value --app thammen-app-123

# ─────────────────────────────────────
# CORS — Restrict which domains can call the API
# ─────────────────────────────────────
# Comma-separated list of allowed origins. Default = thammen.qa production domains.
# For local development: ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
# For testing only: ALLOWED_ORIGINS=*  (NOT recommended for production)
ALLOWED_ORIGINS=https://thammen.qa,https://www.thammen.qa

# ─────────────────────────────────────
# Rate Limiting — Prevent abuse
# ─────────────────────────────────────
# Format: "<count>/<period>" where period is second|minute|hour|day
# Default: 10/minute  (10 evaluations per minute per IP)
# Stricter: 5/minute
# Looser (development): 100/minute
RATE_LIMIT=10/minute

# ─────────────────────────────────────
# Logging
# ─────────────────────────────────────
# Values: DEBUG | INFO | WARNING | ERROR
# DEBUG is verbose, INFO is balanced, WARNING shows issues only
LOG_LEVEL=INFO

# ─────────────────────────────────────
# Data Paths
# ─────────────────────────────────────
# Path to MoJ CSV file (relative to working directory)
MOJ_CSV_PATH=moj_weekly.csv

# Path to MoJ SQLite database (built from CSV at startup)
MOJ_DB_PATH=moj_weekly.db
